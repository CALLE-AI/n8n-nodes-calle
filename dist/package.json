{
    "name": "@call-e/n8n-nodes-calle",
    "version": "0.1.3",
    "description": "n8n community node for creating and monitoring CALL-E AI-agent phone-call tasks.",
    "license": "MIT",
    "homepage": "https://docs.heycall-e.com/",
    "main": "dist/nodes/Calle/Calle.node.js",
    "keywords": [
        "n8n-community-node-package",
        "n8n",
        "call-e",
        "calle",
        "phone-call",
        "ai-agent"
    ],
    "author": {
        "name": "Derek Wang",
        "email": "derekwang0282@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CALLE-AI/n8n-nodes-calle.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "test": "npm run build && node --test test/*.test.mjs",
        "release": "n8n-node release",
        "prepublishOnly": "npm run lint && npm test"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/CalleApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/Calle/Calle.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
